    37→  onOpenMobileConnect: SidebarProps['onOpenMobileConnect']
    38→  renderProjectItem: (project: Project) => React.ReactElement
    39→}
    40→
    41→export function SidebarContent(props: SidebarContentProps): React.ReactElement {
    42→  const {
    43→    state,
    44→    handlers,
    45→    projects,
    46→    activeTabId,
