   329→        }}
   330→        onToggleApi={async (project) => {
   331→          await handleToggleApi(project)
   332→          setContextMenu(null)
   333→        }}
   334→        onOpenMobileConnect={onOpenMobileConnect}
   335→      />
   336→
   337→      {/* Context Menu */}
   338→      {contextMenu && (
   339→        <ProjectContextMenu
   340→          x={contextMenu.x}
   341→          y={contextMenu.y}
   342→          project={contextMenu.project}
   343→          categories={categories}
   344→          onClose={() => setContextMenu(null)}
   345→          onRunExecutable={() => handleRunExecutable(contextMenu.project)}
   346→          onSelectExecutable={() => handleSelectExecutable(contextMenu.project)}
   347→          onClearExecutable={() => handleClearExecutable(contextMenu.project)}
   348→          onOpenSettings={async () => {
   349→            await handleOpenProjectSettings(contextMenu.project)
   350→            setContextMenu(null)
   351→          }}
   352→          onOpenExtensions={() => {
   353→            setExtensionBrowserModal({ project: contextMenu.project })
   354→            setContextMenu(null)
   355→          }}
   356→          onEditClaudeMd={() => {
   357→            setClaudeMdEditorModal({ project: contextMenu.project })
   358→            setContextMenu(null)
   359→          }}
   360→          onUpdateColor={(color) => onUpdateProject(contextMenu.project.path, { color })}
   361→          onMoveToCategory={(categoryId) =>
   362→            moveProjectToCategory(contextMenu.project.path, categoryId)
   363→          }
   364→          onCreateCategory={() => {
   365→            const newId = addCategory('New Category')
   366→            moveProjectToCategory(contextMenu.project.path, newId)
   367→            setContextMenu(null)
   368→            setEditingCategory({ id: newId, name: 'New Category' })
   369→            setTimeout(() => categoryEditInputRef.current?.select(), 0)
   370→          }}
   371→          onDelete={() => {
   372→            setDeleteConfirmModal({ project: contextMenu.project })
   373→            setContextMenu(null)
   374→          }}
   375→        />
   376→      )}
   377→
   378→      {/* Delete Confirmation Modal */}
   379→      {deleteConfirmModal && (
   380→        <DeleteConfirmModal
   381→          project={deleteConfirmModal.project}
   382→          onClose={() => setDeleteConfirmModal(null)}
   383→          onConfirm={() => {
   384→            onRemoveProject(deleteConfirmModal.project.path)
   385→            setDeleteConfirmModal(null)
   386→          }}
   387→        />
   388→      )}
   389→
   390→      {/* Project Settings Modal */}
   391→      {projectSettingsModal && (
   392→        <ProjectSettingsModal
   393→          state={projectSettingsModal}
   394→          globalPermissions={globalPermissions}
   395→          globalVoiceSettings={globalVoiceSettings}
   396→          installedVoices={installedVoices}
   397→          onClose={() => setProjectSettingsModal(null)}
   398→          onSave={handleSaveProjectSettings}
   399→          onChange={handleProjectSettingsChange}
   400→          onToggleTool={handleToggleTool}
   401→          onAllowAll={handleAllowAll}
   402→          onClearAll={handleClearAll}
   403→        />
   404→      )}
   405→
   406→      {/* Extension Browser Modal */}
   407→      {extensionBrowserModal && (
   408→        <ExtensionBrowser
   409→          projectPath={extensionBrowserModal.project.path}
   410→          projectName={extensionBrowserModal.project.name}
   411→          onClose={() => setExtensionBrowserModal(null)}
   412→        />
   413→      )}
   414→
   415→      {/* CLAUDE.md Editor Modal */}
   416→      {claudeMdEditorModal && (
   417→        <ClaudeMdEditor
   418→          isOpen={true}
   419→          projectPath={claudeMdEditorModal.project.path}
   420→          projectName={claudeMdEditorModal.project.name}
   421→          onClose={() => setClaudeMdEditorModal(null)}
   422→        />
   423→      )}
   424→
   425→      {/* Category Context Menu */}
   426→      {categoryContextMenu && (
   427→        <CategoryContextMenu
   428→          x={categoryContextMenu.x}
   429→          y={categoryContextMenu.y}
   430→          category={categoryContextMenu.category}
   431→          onRename={() => {
   432→            handleStartCategoryRename(categoryContextMenu.category)
   433→            setCategoryContextMenu(null)
   434→          }}
   435→          onDelete={() => {
   436→            removeCategory(categoryContextMenu.category.id)
   437→            setCategoryContextMenu(null)
   438→          }}
   439→        />
   440→      )}
   441→    </>
   442→  )
   443→}
