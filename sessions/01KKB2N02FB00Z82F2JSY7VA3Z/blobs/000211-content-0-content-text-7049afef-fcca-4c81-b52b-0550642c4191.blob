     1→import { describe, it, expect, vi, beforeEach, afterEach, Mock } from 'vitest'
     2→
     3→// Mock crypto for UUID generation
     4→vi.stubGlobal('crypto', {
     5→  randomUUID: vi.fn().mockReturnValue('test-uuid-12345'),
     6→})
     7→
     8→// Mock node-pty
     9→const mockPtyProcess = {
    10→  onData: vi.fn(),
    11→  onExit: vi.fn(),
    12→  write: vi.fn(),
    13→  resize: vi.fn(),
    14→  kill: vi.fn(),
    15→}
    16→
    17→vi.mock('node-pty', () => ({
    18→  spawn: vi.fn().mockImplementation(() => mockPtyProcess),
    19→}))
    20→
    21→// Mock fs for executable checking
    22→vi.mock('fs', () => ({
    23→  existsSync: vi.fn().mockReturnValue(false),
    24→}))
    25→
    26→// Mock platform module
    27→vi.mock('../platform', () => ({
    28→  isWindows: false,
    29→  getEnhancedPathWithPortable: vi
    30→    .fn()
    31→    .mockReturnValue('/usr/bin:/usr/local/bin'),
    32→  getAdditionalPaths: vi.fn().mockReturnValue(['/usr/local/bin']),
    33→}))
    34→
    35→// Mock portable-deps module
    36→vi.mock('../portable-deps', () => ({
    37→  getPortableBinDirs: vi.fn().mockReturnValue([]),
    38→}))
    39→
    40→import { PtyManager } from '../pty-manager'
    41→import * as pty from 'node-pty'
    42→import * as fs from 'fs'
    43→import * as platform from '../platform'
    44→
    45→describe('PtyManager', () => {
    46→  let manager: PtyManager
    47→  let dataCallback: ((data: string) => void) | null = null
    48→  let exitCallback: ((result: { exitCode: number }) => void) | null = null
    49→
    50→  beforeEach(() => {
    51→    vi.clearAllMocks()
    52→
    53→    // Reset mock implementations
    54→    dataCallback = null
    55→    exitCallback = null
    56→
    57→    mockPtyProcess.onData.mockImplementation((cb: (data: string) => void) => {
    58→      dataCallback = cb
    59→    })
    60→    mockPtyProcess.onExit.mockImplementation(
    61→      (cb: (result: { exitCode: number }) => void) => {
    62→        exitCallback = cb
    63→      }
    64→    )
    65→
    66→    manager = new PtyManager()
    67→  })
    68→
    69→  afterEach(() => {
    70→    vi.restoreAllMocks()
    71→  })
    72→
    73→  describe('spawn()', () => {
    74→    it('should spawn a PTY process and return an ID', () => {
    75→      const id = manager.spawn('/test/dir')
    76→
    77→      expect(id).toBe('test-uuid-12345')
    78→      expect(pty.spawn).toHaveBeenCalledWith(
    79→        'claude',
    80→        [],
    81→        expect.objectContaining({
    82→          name: 'xterm-256color',
    83→          cols: 120,
    84→          rows: 30,
    85→          cwd: '/test/dir',
    86→          handleFlowControl: true,
    87→        })
    88→      )
    89→    })
    90→
    91→    it('should spawn with resume session ID', () => {
    92→      manager.spawn('/test/dir', 'session-123')
    93→
    94→      expect(pty.spawn).toHaveBeenCalledWith(
    95→        'claude',
    96→        ['-r', 'session-123'],
    97→        expect.any(Object)
    98→      )
    99→    })
   100→
