   260→  describe('resize()', () => {
   261→    beforeEach(() => {
   262→      vi.useFakeTimers()
   263→    })
   264→
   265→    afterEach(() => {
   266→      vi.useRealTimers()
   267→    })
   268→
   269→    it('should resize the PTY process after debounce', () => {
   270→      const id = manager.spawn('/test/dir')
   271→
   272→      manager.resize(id, 200, 50)
   273→
   274→      // Not called immediately (debounced)
   275→      expect(mockPtyProcess.resize).not.toHaveBeenCalled()
   276→
   277→      // Advance past debounce period (50ms for non-Ink backends)
   278→      vi.advanceTimersByTime(60)
   279→
   280→      expect(mockPtyProcess.resize).toHaveBeenCalledWith(200, 50)
   281→    })
   282→
   283→    it('should debounce rapid resize calls', () => {
   284→      const id = manager.spawn('/test/dir')
   285→
   286→      manager.resize(id, 100, 30)
   287→      manager.resize(id, 150, 40)
   288→      manager.resize(id, 200, 50)
   289→
   290→      vi.advanceTimersByTime(60)
   291→
   292→      // Only the last resize should fire
   293→      expect(mockPtyProcess.resize).toHaveBeenCalledTimes(1)
   294→      expect(mockPtyProcess.resize).toHaveBeenCalledWith(200, 50)
   295→    })
   296→
   297→    it('should skip resize if dimensions unchanged', () => {
   298→      const id = manager.spawn('/test/dir')
   299→
   300→      manager.resize(id, 200, 50)
   301→      vi.advanceTimersByTime(60)
   302→      mockPtyProcess.resize.mockClear()
   303→
   304→      // Same dimensions again
   305→      manager.resize(id, 200, 50)
   306→      vi.advanceTimersByTime(60)
   307→
   308→      expect(mockPtyProcess.resize).not.toHaveBeenCalled()
   309→    })
   310→
   311→    it('should use longer debounce for Ink-based backends during startup', () => {
   312→      const id = manager.spawn('/test/dir', undefined, undefined, undefined, undefined, 'gemini')
   313→
   314→      manager.resize(id, 200, 50)
   315→
   316→      // At 60ms - should NOT have fired (Ink startup debounce is 1500ms)
   317→      vi.advanceTimersByTime(60)
   318→      expect(mockPtyProcess.resize).not.toHaveBeenCalled()
   319→
   320→      // At 1600ms - should have fired
   321→      vi.advanceTimersByTime(1500)
   322→      expect(mockPtyProcess.resize).toHaveBeenCalledWith(200, 50)
   323→    })
   324→
   325→    it('should do nothing for non-existent process ID', () => {
   326→      manager.resize('non-existent-id', 200, 50)
   327→      vi.advanceTimersByTime(60)
   328→
   329→      expect(mockPtyProcess.resize).not.toHaveBeenCalled()
   330→    })
   331→
   332→    it('should handle resize errors gracefully (e.g., PTY already exited)', () => {
   333→      const id = manager.spawn('/test/dir')
   334→      mockPtyProcess.resize.mockImplementationOnce(() => {
   335→        throw new Error('pty already closed')
   336→      })
   337→
   338→      manager.resize(id, 200, 50)
   339→      // Should not throw when debounce fires
   340→      expect(() => vi.advanceTimersByTime(60)).not.toThrow()
   341→    })
   342→  })
